-- отключаем отображение информационных сообщений
\set QUIET on

-- прекращаем обработку команд после возникновения ошибки, в интерактивном режиме psql вернётся в командную строку
\set ON_ERROR_STOP on

-- игнорируем ошибки только в интерактивных сеансах, но не в скриптах
\set ON_ERROR_ROLLBACK interactive

-- для каждой базы данных ведём отдельный файл истории выполненных команд
\set HISTFILE ~/.psql_history.:DBNAME

-- устанавливаем максимальное число команд, которые будут сохраняться в истории команд (по умолчанию 500)
\set HISTSIZE 9000

-- не добавляем в историю строки, которые в ней уже есть
\set HISTCONTROL ignoredups

-- пейджер (если результат запроса не помещается на экране, он пропускается через эту программу)
\setenv PSQL_PAGER 'less -iMFXSx4R'
\if `command -v pspg > /dev/null && echo 1 || echo 0`
    \pset expanded off
    \setenv PSQL_PAGER 'pspg --reprint-on-exit --blackwhite'
    \setenv PSQL_WATCH_PAGER 'pspg --reprint-on-exit --blackwhite --stream'
\endif

-- отображаем в таблицах рамки с непрерывными линиями
\pset linestyle unicode

-- отображаем значения NULL
\pset null '¤'

SELECT
    pg_backend_pid(),
    pg_is_in_recovery(),
    (select setting from pg_settings where name = 'data_directory' limit 1) as data_directory,

    pg_postmaster_start_time()::timestamptz(0) as started_at,
    pg_conf_load_time()::timestamptz(0)        as loaded_at,
    now()::timestamptz(0) - pg_postmaster_start_time()::timestamptz(0) as start_uptime,
    now()::timestamptz(0) - pg_conf_load_time()::timestamptz(0)        as load_uptime,

    regexp_replace(coalesce(
      -- example: Postgres Pro (shardman) 18.3.2 on x86_64-pc-linux-gnu, compiled by gcc (GCC) 13.3.1 20250418 (RED SOFT 13.3.1-3), 64-bit
      (select setting from pg_settings where name = 'pgpro_version'),

      -- example: PostgreSQL 18.3 on x86_64-pc-linux-gnu, compiled by gcc (GCC) 13.3.1 20250418 (RED SOFT 13.3.1-3), 64-bit
      -- example: PostgreSQL 16.11 (Ubuntu 16.11-1.pgdg24.04+1) on x86_64-pc-linux-gnu, compiled by gcc (Ubuntu 13.3.0-6ubuntu2~24.04) 13.3.0, 64-bit
      version()
    ), '(?<=\d\.\d+) (on |\().+', '') as pg_version,

    coalesce((select string_agg(concat(coalesce(client_hostname, client_addr::text, '¤'), ':', client_port), ', ' order by backend_start)
                from pg_stat_replication), '') as wal_send_to,
    (SELECT COUNT(*) FROM pg_stat_replication) as wal_send_count,

    coalesce((select concat(sender_host, ':', sender_port) from pg_stat_wal_receiver limit 1), '') as wal_receive_from,
    (SELECT COUNT(*) FROM pg_stat_wal_receiver) as wal_receive_count
\gset

-- настраиваем приглашение командной строки
-- YYYY-MM-DD HH:MM:SS+HH:MM  pg_version  user@host:port/database
\set PROMPT1 '\n%`date --rfc-3339=seconds`  ':pg_version'  %n@%M:%>/%/\n%R%x%# '

\if :{?data_directory}
\else
    -- если прав доступа не хватило, то пробуем получить data_directory альтернативным способом
    \set data_directory `ps -p $(ps -p :pg_backend_pid -o ppid=) -o cmd= | grep -o -P -- ' -D \K[^ ]+'`
\endif

-- определяем роль СУБД - мастер или реплика
\if `test -r :data_directory && test -x :data_directory && echo 1 || echo 0`
    -- если прав доступа хватило
    \set is_primary `test -f :data_directory/standby.signal && echo 0 || echo 1`
\endif

\if :{?is_primary}
\else
    -- если прав доступа не хватило, получаем is_primary альтернативным способом
    -- но определять роль СУБД через SQL функцию pg_is_in_recovery() не всегда корректно
    \set is_primary `test :pg_is_in_recovery = f && echo 1 || echo 0`
\endif

-- выводим информационные сообщения
\echo 'Started at:       ':started_at' (':start_uptime' ago)'
\echo 'Config loaded at: ':loaded_at' (':load_uptime' ago)'
\echo 'Data directory:   ':data_directory
\if :is_primary
    \echo 'Server role:      primary'
\else
    \echo 'Server role:      replica'
    \echo 'WAL receive (':wal_receive_count'):  ':wal_receive_from
\endif
\echo 'WAL send (':wal_send_count'):     ':wal_send_to

-- включаем отображение длительности выполнения запроса
\timing on

-- включаем отображение информационных сообщений
\set QUIET off
